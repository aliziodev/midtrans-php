{
  "name": "aliziodev/midtrans-php",
  "description": "Unofficial PHP SDK for Midtrans API (Snap, Core API, Subscriptions, and webhook utilities).",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "midtrans",
    "payments",
    "php-sdk",
    "unofficial"
  ],
  "authors": [
    {
      "name": "Aliziodev",
      "email": "support@aliziodev.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5",
    "phpstan/phpstan": "^1.12"
  },
  "autoload": {
    "psr-4": {
      "Aliziodev\\MidtransPhp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Aliziodev\\MidtransPhp\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:unit": "phpunit --testsuite unit",
    "test:integration": "phpunit --testsuite integration",
    "analyse": "phpstan analyse --memory-limit=256M",
    "qa": [
      "composer validate --strict",
      "composer analyse",
      "composer test:unit",
      "composer audit"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
